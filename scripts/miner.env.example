#!/usr/bin/env bash
# Copy to scripts/miner.env and edit values before running:
#   cp scripts/miner.env.example scripts/miner.env
#   bash ./scripts/run_miner.sh
#
# Variables marked "export" are read by neurons/miner.py at runtime.
# Other variables are consumed by scripts/run_miner.sh only.

# ── Required: wallet ────────────────────────────────────────────────────────
WALLET_NAME="miner"
WALLET_HOTKEY="default"

# ── Required: subnet ────────────────────────────────────────────────────────
NETUID="1"
NETWORK="finney"
# Optional chain override (local node, custom endpoint). Leave empty for NETWORK default.
export SUBTENSOR_CHAIN_ENDPOINT=""

# ── Required: axon reachability ─────────────────────────────────────────────
# Public IP (or hostname) validators use to reach this miner. Must be routable.
export MINER_EXTERNAL_IP=""
# Bind address/port on this machine. MINER_EXTERNAL_PORT defaults to MINER_PORT.
export MINER_IP="0.0.0.0"
MINER_PORT="9000"
export MINER_EXTERNAL_PORT=""
export AXON_MAX_WORKERS="10"

# ── Launcher (run_miner.sh) ─────────────────────────────────────────────────
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
LOGGING_DIR="./logs"
# Extra CLI flags appended to neurons/miner.py (e.g. --logging-dir /data/logs)
MINER_EXTRA_ARGS=""

# ── Subtensor / metagraph retries ─────────────────────────────────────────────
export SUBTENSOR_CONNECT_RETRIES="5"
export SUBTENSOR_CONNECT_RETRY_SECONDS="4"
export METAGRAPH_SYNC_RETRIES="5"
export METAGRAPH_SYNC_RETRY_SECONDS="4"

# ── Validator acceptance gates (preflight mirror) ───────────────────────────
# Must stay aligned with neurons/validator.py::verify_and_score and
# perturbnet/constants.py defaults. Used to predict validator rejections.
export MINER_VAL_MIN_LINF="0.003"
export MINER_VAL_MAX_LINF="0.00393"
export MINER_VAL_MIN_SSIM="0.98"
export MINER_VAL_MIN_PSNR_DB="38.0"

# ── Attack / inference tuning ─────────────────────────────────────────────────
# Minimum logit margin required for a flip to survive validator re-inference.
export MINER_FLIP_MARGIN_EPS="0.4"
# Disable TF32 so local flip checks match validator numerics more closely.
export MINER_DISABLE_TF32="1"
# Set to 1 to call torch.cuda.empty_cache() after each forward (usually off).
# export MINER_CUDA_EMPTY_CACHE="0"

# ── Estimated score alignment (Excel + preflight) ─────────────────────────────
# Read by perturbnet.constants at import time; keep in sync with validator scoring.
export PERTURB_MIN_LINF_DELTA="0.003"
export PERTURB_MAX_LINF_DELTA="0.03"
export PERTURB_MIN_SSIM="0.98"
export PERTURB_MIN_PSNR_DB="38.0"
export PERTURB_LINF_COMPONENT_WEIGHT="0.7"
export PERTURB_RMSE_COMPONENT_WEIGHT="0.3"
export PERTURB_PERTURBATION_WEIGHT="1"
export PERTURB_SPEED_WEIGHT="0"
export PERTURB_TIMEOUT_SECONDS="15"
