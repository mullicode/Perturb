#!/usr/bin/env bash
# Copy to scripts/validator.env and edit values before running:
#   cp scripts/validator.env.example scripts/validator.env
#   bash ./scripts/run_validator.sh

# Required wallet fields
WALLET_NAME="validator"
WALLET_HOTKEY="default"

# Network
NETUID="1"
NETWORK="finney"

# Optional Python and extra CLI flags
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
VALIDATOR_EXTRA_ARGS=""

export PERTURB_PEXELS_API_KEY=""
export PERTURB_WANDB_ENABLED="false"
export WANDB_API_KEY=""