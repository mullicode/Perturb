#!/usr/bin/env bash
# Copy to scripts/validator.env and edit values before running:
#   cp scripts/validator.env.example scripts/validator.env
#   bash ./scripts/run_validator.sh

# Required wallet fields
WALLET_NAME="validator"
WALLET_HOTKEY="default"

# Network
NETUID="1"
NETWORK="finney"

# Optional Python and extra CLI flags
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
# Optional validator port (maps to --axon.port)
VALIDATOR_PORT="8090"
VALIDATOR_EXTRA_ARGS=""

# Validator runtime tuning (read by perturbnet/constants.py)
export PERTURB_IMAGE_ENDPOINT="https://api.pexels.com/v1/search"
export PERTURB_PEXELS_API_KEY=""
export PERTURB_PEXELS_PER_PAGE="40"
export PERTURB_PEXELS_PAGE_SPAN="10"
export PERTURB_PEXELS_IMAGE_VARIANT="medium"
export PERTURB_IMAGE_SIZE="64"
export PERTURB_TIMEOUT_SECONDS="60"
export PERTURB_QUERY_INTERVAL_SECONDS="120"
export PERTURB_K_MINERS="8"
export PERTURB_HISTORY_SIZE="100"
export PERTURB_MIN_PROCESSED_COUNT="100"
export PERTURB_MIN_LINF_DELTA="0.002"
export PERTURB_MAX_LINF_DELTA="0.12"
export PERTURB_MIN_SSIM="0.98"
export PERTURB_MIN_PSNR_DB="38.0"
export PERTURB_MAX_CHALLENGE_ATTEMPTS="12"
export PERTURB_PERTURBATION_WEIGHT="1.0"
export PERTURB_SPEED_WEIGHT="0.0"

# Local validator-hosted llm_endpoint url + model hint
export PERTURB_LLM_ENDPOINT_URL="http://127.0.0.1:8081/verify-label"
export PERTURB_LLM_ENDPOINT_MODEL="Qwen2.5-1.5B-Instruct"
export PERTURB_LLM_ENDPOINT_TIMEOUT_SECONDS="20"

# Optional backward-compat env names (not required):
# export PERTURB_LABEL_MATCH_ENDPOINT="http://127.0.0.1:8081/match-label"
# export PERTURB_LABEL_MATCH_MODEL="Qwen2.5-1.5B-Instruct"
# export PERTURB_REQUIRE_LABEL_MATCH="true"
# export PERTURB_LLM_VERIFY_ENDPOINT="http://127.0.0.1:8081/verify-label"
# export PERTURB_LLM_VERIFY_MODEL="Qwen2.5-1.5B-Instruct"
# export PERTURB_REQUIRE_LLM_VERIFY="true"
